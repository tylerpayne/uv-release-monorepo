    inputs:
      plan:
        description: "Release plan JSON (generated automatically by `uvr release`)."
        type: string
        required: true

permissions:
[% for scope, level in permissions.items() | sort %]
  [[ scope ]]: [[ level ]]
[% endfor %]
[% set pre_release_needs = ['post-build'] if hooks.post_build else ['build'] %]
[% set publish_needs = ['pre-release'] if hooks.pre_release else pre_release_needs %]
[%- macro hook_job_attrs(phase) -%]
[% set job = hook_jobs.get(phase, {}) %]
[% for key, val in job.items() if key != 'runs-on' %]
    [[ key ]]: [[ val ]]
[% endfor %]
[%- endmacro -%]
[# All plan fields are accessed via fromJSON(inputs.plan).field_name #]
[% set p = "fromJSON(inputs.plan)" %]

jobs:
[% if hooks.pre_build %]
  pre-build:
    if: ${{ !contains([[ p ]].skip, 'pre-build') }}
    runs-on: [[ hook_jobs.get('pre_build', {}).get('runs-on', 'ubuntu-latest') ]]
[[ hook_job_attrs('pre_build') ]]
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - name: Export plan context
        env:
          UVR_PLAN: ${{ inputs.plan }}
        run: |
          echo "UVR_CHANGED=$(echo "$UVR_PLAN" | jq -r '.changed | keys | join(" ")')" >> "$GITHUB_ENV"
          echo "UVR_PLAN=$UVR_PLAN" >> "$GITHUB_ENV"
[% for step in hooks.pre_build %]
