[% endfor %]
[% endif %]
  build:
    if: ${{ !contains([[ p ]].skip, 'build') }}
[% if hooks.pre_build %]
    needs: [pre-build]
[% endif %]
    strategy:
      fail-fast: false
      matrix:
        runner: ${{ [[ p ]].runners }}
    runs-on: ${{ matrix.runner }}
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - uses: astral-sh/setup-uv@v5
      - name: Set up Python
        run: |
          uv python install ${{ [[ p ]].python_version }}
          uv tool install ${{ [[ p ]].uvr_version != '' && format('uv-release-monorepo=={0}', [[ p ]].uvr_version) || 'uv-release-monorepo' }}
      - name: Build packages
        env:
          GH_TOKEN: ${{ github.token }}
          UVR_PLAN: ${{ inputs.plan }}
        run: uvr-steps build-all --plan "$UVR_PLAN" --runner '${{ matrix.runner }}'
      - uses: actions/upload-artifact@v4
        with:
          name: wheels-${{ matrix.runner }}
          path: dist/*.whl
          if-no-files-found: error

[% if hooks.post_build %]
  post-build:
    if: ${{ always() && !failure() && !contains([[ p ]].skip, 'post-build') }}
    runs-on: [[ hook_jobs.get('post_build', {}).get('runs-on', 'ubuntu-latest') ]]
    needs: [build]
[[ hook_job_attrs('post_build') ]]
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - name: Export plan context
        env:
          UVR_PLAN: ${{ inputs.plan }}
        run: |
          echo "UVR_CHANGED=$(echo "$UVR_PLAN" | jq -r '.changed | keys | join(" ")')" >> "$GITHUB_ENV"
          echo "UVR_PLAN=$UVR_PLAN" >> "$GITHUB_ENV"
[% for step in hooks.post_build %]
